generator client {
  provider = "prisma-client"
  output   = "../src/prisma"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id        String   @id @default(cuid())
  name      String
  prefix    String   @default("!")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  username      String
  discriminator String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
